# .env.example — WatsonX SAP Commodity Pricing
# Copy this file to .env.local and fill in your real values.
# Never commit real credentials to version control.

# ─── AI Provider (IBM watsonx — PRIMARY) ─────────────────────────────────────
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_REGION=us-south
WATSONX_TEXT_MODEL=ibm/granite-3-8b-instruct

# ─── AI Provider (Google Gemini — FALLBACK only) ─────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
AI_TIMEOUT_MS=15000

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ─── Live Price Fetch (Yahoo Finance — no key required, public endpoint) ─────
# No key needed. The /api/industry/:slug/refresh endpoint uses
# https://query1.finance.yahoo.com/v8/finance/chart/<ticker>
# Optionally set a proxy if the server is behind a corporate firewall:
YAHOO_FINANCE_PROXY=

# ─── SAP Industry Seed ───────────────────────────────────────────────────────
# Run the seed script to generate all industry Excel workbooks:
#   npx tsx scripts/seedIndustryData.ts
# Output location: data/industries/<slug>/master_data.xlsx
# Each workbook has 20 SAP table sheets × 500 records.
